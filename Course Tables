import boto3
from botocore.exceptions import ClientError
from boto3.dynamodb.conditions import Attr

REGION = "us-east-1"
TABLE_NAME = "Courses"

# Initialize the DynamoDB Service Resource targeted at the us-east-1 region
dynamodb = boto3.resource('dynamodb', region_name=REGION)


def create_courses_table():
    """
    Creates the 'Courses' table in DynamoDB if it doesn't already exist.
    DynamoDB Table resource
    """
    print("Checking/Creating 'Courses' table...")
    try:
        # Define table schema using On-Demand provisioning (PAY_PER_REQUEST)
        table = dynamodb.create_table(
            TableName=TABLE_NAME,
            KeySchema=[
                {'AttributeName': 'CourseID', 'KeyType': 'HASH'}  # Partition Key
            ],
            AttributeDefinitions=[
                {'AttributeName': 'CourseID', 'AttributeType': 'S'}  # 'S' = String type
            ],
            BillingMode='PAY_PER_REQUEST'
        )
        print("Waiting for table to become active...")
        # Pause until AWS confirms the table is fully active
        table.wait_until_exists()
        print("Table 'Courses' created successfully!")
        return table

    except ClientError as e:
        # If table already exists, catch gracefully and return the active object
        if e.response['Error']['Code'] == 'ResourceInUseException':
            print("Table 'Courses' already exists. Proceeding...")
            return dynamodb.Table(TABLE_NAME)

        print(f"Unexpected error during table creation: {e}")
        raise


