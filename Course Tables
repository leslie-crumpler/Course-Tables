def interactive_search(table):
    """
    Runs an interactive loop prompting the user for a course Subject and
    Catalog Number. Includes explicit data validation and loops until the
    user chooses to exit.
    """
    while True:  # OUTER LOOP: repeats until user enters N.

        # Subject input and validation loop
        while True:
            print("Enter the Subject:")
            subject = input().strip().upper()
            if subject:
                break
            print("A Subject is required. Enter the Subject:")

        # Catalog Number input and validation loop
        while True:
            print("Enter the CatalogNbr:")
            catalog_nbr = input().strip()
            if catalog_nbr:
                break
            print("A CatalogNbr is required. Enter the CatalogNbr:")

        print(f"Searching for {subject} {catalog_nbr}...")

        try:
            # Scan the table filtering by Subject and CatalogNbr
            response = table.scan(
                FilterExpression=(
                    Attr('Subject').eq(subject) &
                    Attr('CatalogNbr').eq(catalog_nbr)
                )
            )

            items = response.get('Items', [])

            # Print result or a not-found message
            if items:
                for item in items:
                    print(
                        f"The title of {subject} "
                        f"{catalog_nbr} is {item.get('Title')}."
                    )
            else:
                print(
                    f"No courses found matching "
                    f"{subject} {catalog_nbr}."
                )

        except ClientError as e:
            print(f"Search encountered an error: {e}")

        # Continuation prompt — inside outer loop so the program repeats
        while True:
            print("Would you like to search for another title? (Y or N)")
            repeat = input().strip().upper()

            if repeat in ('Y', 'N'):
                break

            print("Invalid option. Please enter Y or N.")

        if repeat == 'N':
            print("Thanks for using the Catalog Search program.")
            break  # exits the outer while True loop


if __name__ == "__main__":
    # Orchestrate the full database lifecycle workflow
    courses_table = create_courses_table()
    populate_course_data(courses_table)
    interactive_search(courses_table) 
